# ═══════════════════════════════════════════
# Portal Cateno — Variáveis de Ambiente
# Copie para .env.local e preencha os valores
# ═══════════════════════════════════════════

# ── App ──
NEXT_PUBLIC_APP_NAME=Portal Cateno
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Database (Prisma + PostgreSQL via Docker) ──
DATABASE_URL="postgresql://cateno:cateno_dev@localhost:5432/portal_cateno?schema=public"

# ── Auth (NextAuth.js 5 + Keycloak) ──
NEXTAUTH_URL=http://localhost:3000
AUTH_SECRET=gere-com-openssl-rand-base64-32
AUTH_KEYCLOAK_ID=portal-cateno
AUTH_KEYCLOAK_SECRET=portal-cateno-dev-secret
AUTH_KEYCLOAK_ISSUER=http://localhost:8080/realms/cateno

# ── Health Checker ──
HEALTH_CHECKER_SECRET=gere-com-openssl-rand-hex-32

# ── AI (CatIA — LangChain.js + Gemini) ──
AI_PROVIDER=google
AI_MODEL=gemini-2.0-flash
GOOGLE_AI_API_KEY=

# ── Langflow (Docker, profile "ai") ──
LANGFLOW_PORT=7860

# ── Observability ──
NEXT_PUBLIC_SENTRY_DSN=
