# ═══════════════════════════════════════════
# CSA - CatIA Super App — Variáveis de Ambiente
# Copie para .env.local e preencha os valores
# ═══════════════════════════════════════════

# ── App ──
NEXT_PUBLIC_APP_NAME=CatIA Super App
NEXT_PUBLIC_APP_SHORT_NAME=CSA
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ── Database (Prisma + PostgreSQL via Docker) ──
DATABASE_URL="postgresql://cateno:cateno_dev@localhost:5432/csa?schema=public"

# ── Auth (NextAuth.js 5 + Keycloak) ──
NEXTAUTH_URL=http://localhost:3000
AUTH_SECRET=gere-com-openssl-rand-base64-32
AUTH_KEYCLOAK_ID=csa
AUTH_KEYCLOAK_SECRET=csa-dev-secret
AUTH_KEYCLOAK_ISSUER=http://localhost:8080/realms/cateno

# ── Kong API Gateway ──
KONG_DB_PASSWORD=kong_dev_password

# ── Health Checker ──
HEALTH_CHECKER_SECRET=gere-com-openssl-rand-hex-32
# Em dev (portal com npm run dev): http://host.docker.internal:3000
# Em produção (portal no Docker): http://portal:3000
PORTAL_URL=http://host.docker.internal:3000

# ── CatIA — Multi-Model (SDKs nativos) ──
# Orquestrador — planeja e roteia
CATIA_ORCHESTRATOR_PROVIDER=google
CATIA_ORCHESTRATOR_MODEL=gemini-2.5-pro
# Tool Calling — executa operações de negócio
CATIA_TOOL_CALL_PROVIDER=anthropic
CATIA_TOOL_CALL_MODEL=claude-sonnet-4-5
# Processamento de documentos
CATIA_DOC_PROCESSOR_PROVIDER=anthropic
CATIA_DOC_PROCESSOR_MODEL=claude-sonnet-4-5
# Respostas simples — velocidade e custo
CATIA_SIMPLE_RESPONSE_PROVIDER=google
CATIA_SIMPLE_RESPONSE_MODEL=gemini-2.5-flash

# ── API Keys ──
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=

# ── Langflow (Docker, profile "ai") ──
LANGFLOW_PORT=7860

# ── CatIA — URL Rewrites (somente dev, ausente em prod) ──
# Mapeia prefixos de URL de produção para URLs locais.
# O banco sempre guarda URLs canônicas (prod); o executor reescreve em runtime.
# Formato: JSON { "prefixo_prod": "url_local" }
# CATIA_URL_REWRITES={"https://api.cateno.com.br/reservas":"http://localhost:3001"}

# ── Observability ──
NEXT_PUBLIC_SENTRY_DSN=
