{
	admin off
	log {
		output stdout
		format json
	}
}

portal.cateno.com.br {
	# Health check do gateway (nao passa pelo Kong)
	handle /healthz {
		respond `{"status":"ok"}` 200
	}

	# Todas as requisicoes passam pelo Kong
	reverse_proxy kong:8000 {
		header_up X-Real-IP {remote.ip}

		# SSE para o CatIA — sem buffering (OBRIGATORIO)
		flush_interval -1
	}
}
